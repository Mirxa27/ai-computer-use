# --- e2b sandbox ---
E2B_API_KEY=
# Optional: id of the custom Kali Linux template built from ./e2b.Dockerfile
# (`e2b template build --name mirxa-kali`). Without it, MirXa Kali falls back
# to the stock e2b Ubuntu desktop.
E2B_TEMPLATE_ID=

# --- AI providers (all optional; users can set per-session in /settings) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Hugging Face token (used by the local model manager for gated/private models)
HF_TOKEN=
